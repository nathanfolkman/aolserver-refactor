# Bundled ExternalProject install prefix (sibling of build dir, not under build/)
/deps-install/

# Local CMake build trees
/build/
/build-h3/
/build-docker-ci/
/build-docker-ci-h3/

# Optional vendored h3spec binary (download from releases; too large for this repo)
/tests/h3test/bin/h3spec

# Self-signed TLS for tests/h2test/minimal.tcl (generated locally; never commit)
/tests/h2test/servers/s1/modules/nsssl/*.pem

# Local h2spec full-run capture (see README "h2spec failure checklist")
/h2spec-full.log
/h2spec-junit.xml
/h2spec-docker.log
/h2spec-docker-junit.xml
